<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
  <title>Mis Vacaciones</title>

  <!-- PWA meta -->
  <link rel="manifest" href="./manifest.json" />
  <meta name="theme-color" content="#1e293b" />
  <meta name="mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="apple-mobile-web-app-title" content="Vacaciones" />
  <meta name="application-name" content="Mis Vacaciones" />
  <meta name="description" content="Gestiona y planifica tus días de vacaciones y ausencias" />
  <link rel="apple-touch-icon" sizes="152x152" href="./icons/icon-152x152.png" />
  <link rel="apple-touch-icon" sizes="192x192" href="./icons/icon-192x192.png" />
  <link rel="icon" type="image/png" sizes="192x192" href="./icons/icon-192x192.png" />
  <link rel="icon" type="image/png" sizes="512x512" href="./icons/icon-512x512.png" />

  <!-- ✅ importmap PRIMERO — obligatorio antes que Babel -->
  <script type="importmap">
  {
    "imports": {
      "react":            "https://esm.sh/react@18",
      "react-dom/client": "https://esm.sh/react-dom@18/client",
      "lucide-react":     "https://esm.sh/lucide-react@0.383.0"
    }
  }
  </script>

  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>

  <!-- Babel Standalone -->
  <script src="https://unpkg.com/@babel/standalone/babel.min.js"></script>

  <style>
    @keyframes fadeIn   { from { opacity: 0 }              to { opacity: 1 } }
    @keyframes zoomIn95 { from { opacity: 0; transform: scale(.95) } to { opacity: 1; transform: scale(1) } }
    @keyframes slideInFromRight { from { transform: translateX(100%) } to { transform: translateX(0) } }

    .animate-in          { animation-fill-mode: both; animation-duration: 200ms; }
    .fade-in             { animation-name: fadeIn; }
    .zoom-in-95          { animation-name: zoomIn95; }
    .slide-in-from-right { animation-name: slideInFromRight; }
    .duration-200        { animation-duration: 200ms; }
    .duration-300        { animation-duration: 300ms; }

    body { margin: 0; padding-top: env(safe-area-inset-top); padding-bottom: env(safe-area-inset-bottom); }
    html { scroll-behavior: smooth; -webkit-tap-highlight-color: transparent; }

    #splash {
      position: fixed; inset: 0; background: #f8fafc;
      display: flex; flex-direction: column; align-items: center; justify-content: center;
      gap: 1rem; z-index: 9999; transition: opacity .4s;
    }
    #splash.hidden { opacity: 0; pointer-events: none; }
    #splash-icon { font-size: 3rem; animation: bounce 1s infinite alternate; }
    @keyframes bounce { to { transform: translateY(-12px); } }
    #splash p { color: #64748b; font-family: system-ui, sans-serif; font-size: .9rem; }

    #install-banner {
      position: fixed; bottom: 1rem; left: 50%; transform: translateX(-50%);
      background: #1e293b; color: white; border-radius: 1rem;
      padding: .75rem 1.25rem; display: flex; align-items: center; gap: .75rem;
      box-shadow: 0 8px 32px rgba(0,0,0,.25); z-index: 1000;
      font-family: system-ui, sans-serif; font-size: .875rem;
      animation: slideUp .3s ease; white-space: nowrap; max-width: calc(100vw - 2rem);
    }
    #install-banner.hidden { display: none; }
    @keyframes slideUp { from { transform: translateX(-50%) translateY(2rem); opacity: 0; } to { transform: translateX(-50%) translateY(0); opacity: 1; } }
    #install-banner button { background: #3b82f6; color: white; border: none; border-radius: .5rem; padding: .4rem .9rem; cursor: pointer; font-weight: 600; font-size: .8rem; flex-shrink: 0; }
    #install-banner button.dismiss { background: transparent; color: #94a3b8; padding: .4rem .5rem; }
  </style>

  <script>
    if ('serviceWorker' in navigator) {
      window.addEventListener('load', () => {
        navigator.serviceWorker.register('./sw.js')
          .then(reg => console.log('[PWA] SW:', reg.scope))
          .catch(err => console.warn('[PWA] SW error:', err));
      });
    }
    let deferredPrompt = null;
    window.addEventListener('beforeinstallprompt', (e) => {
      e.preventDefault(); deferredPrompt = e;
      const b = document.getElementById('install-banner');
      if (b) b.classList.remove('hidden');
    });
    function installPWA() {
      if (!deferredPrompt) return;
      deferredPrompt.prompt();
      deferredPrompt.userChoice.then(() => { deferredPrompt = null; dismissBanner(); });
    }
    function dismissBanner() {
      const b = document.getElementById('install-banner');
      if (b) b.classList.add('hidden');
    }
    window.addEventListener('appinstalled', dismissBanner);
  </script>
</head>
<body>

  <div id="splash">
    <div id="splash-icon">🏖️</div>
    <p>Cargando Mis Vacaciones…</p>
  </div>

  <div id="install-banner" class="hidden">
    <span>📲 Instalar como app</span>
    <button onclick="installPWA()">Instalar</button>
    <button class="dismiss" onclick="dismissBanner()">✕</button>
  </div>

  <div id="root"></div>

  <!--
    ╔══════════════════════════════════════════════════════════════╗
    ║  CÓDIGO ORIGINAL — NO SE HA MODIFICADO NINGUNA LÍNEA        ║
    ╚══════════════════════════════════════════════════════════════╝
  -->
  <script type="text/babel" data-type="module">
import React, { useState, useEffect, useMemo, useRef } from 'react';
import { 
  Calendar, Clock, AlertTriangle, CheckCircle, Plus, 
  Trash2, Edit2, Download, Upload, Info, Briefcase, CalendarDays, PieChart,
  LayoutDashboard, X, ChevronLeft, ChevronRight, ArrowRight, Settings, Save, Palette
} from 'lucide-react';

// --- CONFIGURACIÓN INICIAL ---
const HOURS_PER_DAY = 7.17;
const CURRENT_YEAR = new Date().getFullYear();

const DEFAULT_CATEGORIES = {
  VACACIONES: { 
    id: 'VACACIONES', name: 'Vacaciones', total: 22, unit: 'días', 
    color: 'bg-blue-500', 
    styleSolid: 'bg-blue-500 text-white font-bold', 
    styleLight: 'bg-blue-50 border border-blue-400 text-blue-800' 
  },
  LIBRE_DISPOSICION: { 
    id: 'LIBRE_DISPOSICION', name: 'Libre disposición', total: 3, unit: 'días', 
    color: 'bg-purple-500',
    styleSolid: 'bg-purple-500 text-white font-bold', 
    styleLight: 'bg-purple-50 border border-purple-400 text-purple-800'
  },
  COMPENSACION: { 
    id: 'COMPENSACION', name: 'Compensación horaria', total: 15.33, unit: 'horas', 
    color: 'bg-amber-500',
    styleSolid: 'bg-amber-500 text-white font-bold', 
    styleLight: 'bg-amber-50 border border-amber-400 text-amber-800'
  },
  NAVIDAD: { 
    id: 'NAVIDAD', name: 'Día de Navidad', total: 1, unit: 'días', 
    color: 'bg-emerald-500',
    styleSolid: 'bg-emerald-500 text-white font-bold', 
    styleLight: 'bg-emerald-50 border border-emerald-400 text-emerald-800'
  },
  SS: { 
    id: 'SS', name: 'Día de Semana Santa', total: 1, unit: 'días', 
    color: 'bg-teal-500',
    styleSolid: 'bg-teal-500 text-white font-bold', 
    styleLight: 'bg-teal-50 border border-teal-400 text-teal-800'
  }
};

const COLOR_OPTIONS = [
  { bg: 'bg-blue-500', solid: 'bg-blue-500 text-white font-bold', light: 'bg-blue-50 border border-blue-400 text-blue-800' },
  { bg: 'bg-purple-500', solid: 'bg-purple-500 text-white font-bold', light: 'bg-purple-50 border border-purple-400 text-purple-800' },
  { bg: 'bg-amber-500', solid: 'bg-amber-500 text-white font-bold', light: 'bg-amber-50 border border-amber-400 text-amber-800' },
  { bg: 'bg-emerald-500', solid: 'bg-emerald-500 text-white font-bold', light: 'bg-emerald-50 border border-emerald-400 text-emerald-800' },
  { bg: 'bg-teal-500', solid: 'bg-teal-500 text-white font-bold', light: 'bg-teal-50 border border-teal-400 text-teal-800' },
  { bg: 'bg-red-500', solid: 'bg-red-500 text-white font-bold', light: 'bg-red-50 border border-red-400 text-red-800' },
  { bg: 'bg-pink-500', solid: 'bg-pink-500 text-white font-bold', light: 'bg-pink-50 border border-pink-400 text-pink-800' },
  { bg: 'bg-indigo-500', solid: 'bg-indigo-500 text-white font-bold', light: 'bg-indigo-50 border border-indigo-400 text-indigo-800' },
];

const INITIAL_ENTRIES = [
  { id: '1', category: 'VACACIONES', status: 'pedido', dates: '2 y 4 de enero', dateList: [`${CURRENT_YEAR}-01-02`, `${CURRENT_YEAR}-01-04`], amount: 2 },
  { id: '2', category: 'VACACIONES', status: 'pedido', dates: '16 al 20 de marzo', dateList: [`${CURRENT_YEAR}-03-16`, `${CURRENT_YEAR}-03-17`, `${CURRENT_YEAR}-03-18`, `${CURRENT_YEAR}-03-19`, `${CURRENT_YEAR}-03-20`], amount: 5 },
  { id: '11', category: 'SS', status: 'pedido', dates: '13 de abril', dateList: [`${CURRENT_YEAR}-04-13`], amount: 1 },
  { id: '3', category: 'VACACIONES', status: 'previsto', dates: '29, 30 de junio', dateList: [`${CURRENT_YEAR}-06-29`, `${CURRENT_YEAR}-06-30`], amount: 2 },
  { id: '4', category: 'VACACIONES', status: 'previsto', dates: '1, 2, 3 de julio', dateList: [`${CURRENT_YEAR}-07-01`, `${CURRENT_YEAR}-07-02`, `${CURRENT_YEAR}-07-03`], amount: 3 },
  { id: '5', category: 'VACACIONES', status: 'previsto', dates: '6, 7, 8 de julio', dateList: [`${CURRENT_YEAR}-07-06`, `${CURRENT_YEAR}-07-07`, `${CURRENT_YEAR}-07-08`], amount: 3 },
  { id: '6', category: 'VACACIONES', status: 'previsto', dates: '27 al 31 de julio', dateList: [`${CURRENT_YEAR}-07-27`, `${CURRENT_YEAR}-07-28`, `${CURRENT_YEAR}-07-29`, `${CURRENT_YEAR}-07-30`, `${CURRENT_YEAR}-07-31`], amount: 5 },
  { id: '7', category: 'VACACIONES', status: 'previsto', dates: '29, 30 de diciembre', dateList: [`${CURRENT_YEAR}-12-29`, `${CURRENT_YEAR}-12-30`], amount: 2 },
  { id: '8', category: 'LIBRE_DISPOSICION', status: 'previsto', dates: '28 de diciembre', dateList: [`${CURRENT_YEAR}-12-28`], amount: 1 },
  { id: '9', category: 'COMPENSACION', status: 'previsto', dates: '4 y 5 de enero', dateList: [`${CURRENT_YEAR}-01-04`, `${CURRENT_YEAR}-01-05`], amount: 14 },
  { id: '10', category: 'NAVIDAD', status: 'previsto', dates: '31 de diciembre', dateList: [`${CURRENT_YEAR}-12-31`], amount: 1 }
];

const MONTHS = ['Enero', 'Febrero', 'Marzo', 'Abril', 'Mayo', 'Junio', 'Julio', 'Agosto', 'Septiembre', 'Octubre', 'Noviembre', 'Diciembre'];
const DAYS_OF_WEEK = ['L', 'M', 'X', 'J', 'V', 'S', 'D'];

export default function App() {
  const [entries, setEntries] = useState([]);
  const [categories, setCategories] = useState(DEFAULT_CATEGORIES);
  const [isLoaded, setIsLoaded] = useState(false);
  const [activeTab, setActiveTab] = useState('dashboard');
  const [selectedCategory, setSelectedCategory] = useState(null);
  const [currentYear, setCurrentYear] = useState(CURRENT_YEAR);
  const fileInputRef = useRef(null);

  // Estados del Formulario y Modal
  const [isFormModalOpen, setIsFormModalOpen] = useState(false);
  const [formData, setFormData] = useState({ id: '', category: 'VACACIONES', status: 'pedido', dates: '', dateList: [], amount: '' });
  const [isEditing, setIsEditing] = useState(false);

  // Estados de Selección del Calendario
  const [selectionStart, setSelectionStart] = useState(null);
  const [selectionEnd, setSelectionEnd] = useState(null);
  const [isSelecting, setIsSelecting] = useState(false);

  // Estados de Configuración de Categorías
  const [editingCatId, setEditingCatId] = useState(null);
  const [catEditForm, setCatEditForm] = useState({ name: '', total: '', unit: 'días', color: '' });

  // Estados para añadir/quitar fechas en el Modal
  const [dateInputMode, setDateInputMode] = useState('single'); // 'single' o 'range'
  const [newDateStart, setNewDateStart] = useState('');
  const [newDateEnd, setNewDateEnd] = useState('');

  useEffect(() => {
    const savedData = localStorage.getItem('vacaciones_data');
    const savedCats = localStorage.getItem('vacaciones_categories');
    
    if (savedData) {
      try {
        const parsed = JSON.parse(savedData);
        setEntries(parsed.map(e => ({ ...e, dateList: e.dateList || [] })));
      } catch (e) { setEntries(INITIAL_ENTRIES); }
    } else { setEntries(INITIAL_ENTRIES); }

    if (savedCats) {
      try { setCategories(JSON.parse(savedCats)); } 
      catch (e) { setCategories(DEFAULT_CATEGORIES); }
    }
    
    setIsLoaded(true);
  }, []);

  useEffect(() => {
    if (isLoaded) {
      localStorage.setItem('vacaciones_data', JSON.stringify(entries));
      localStorage.setItem('vacaciones_categories', JSON.stringify(categories));
    }
  }, [entries, categories, isLoaded]);

  const sortedEntries = useMemo(() => {
    return [...entries].sort((a, b) => {
      const dateA = a.dateList && a.dateList.length > 0 ? a.dateList[0] : '0';
      const dateB = b.dateList && b.dateList.length > 0 ? b.dateList[0] : '0';
      if (dateA !== '0' && dateB !== '0') return new Date(dateA) - new Date(dateB);
      return parseInt(a.id) - parseInt(b.id);
    });
  }, [entries]);

  const stats = useMemo(() => {
    const calcStats = {};
    Object.values(categories).forEach(cat => {
      calcStats[cat.id] = { ...cat, pedido: 0, previsto: 0, totalUsado: 0, restante: cat.total, items: [] };
    });
    entries.forEach(entry => {
      if (calcStats[entry.category]) {
        calcStats[entry.category][entry.status] += entry.amount;
        calcStats[entry.category].items.push(entry);
        if (entry.status === 'pedido') {
          calcStats[entry.category].totalUsado += entry.amount;
          calcStats[entry.category].restante -= entry.amount;
        }
      }
    });
    return calcStats;
  }, [entries, categories]);

  const globalStats = useMemo(() => {
    let daysTotal = 0, daysUsed = 0, daysPlanned = 0, daysRemaining = 0;
    Object.values(stats).forEach(stat => {
      const factor = stat.unit === 'horas' ? (1 / HOURS_PER_DAY) : 1;
      daysTotal += stat.total * factor;
      daysUsed += stat.pedido * factor;
      daysPlanned += stat.previsto * factor;
      daysRemaining += stat.restante * factor;
    });
    return { 
      total: parseFloat(daysTotal.toFixed(2)), 
      pedido: parseFloat(daysUsed.toFixed(2)), 
      previsto: parseFloat(daysPlanned.toFixed(2)), 
      restante: parseFloat(daysRemaining.toFixed(2)) 
    };
  }, [stats]);

  const alerts = useMemo(() => {
    const newAlerts = [];
    Object.values(stats).forEach(stat => {
      if (stat.restante < 0) newAlerts.push({ type: 'danger', msg: `¡Límite de ${stat.name} superado por ${Math.abs(stat.restante).toFixed(2)} ${stat.unit}!` });
      else if (stat.restante === 0) newAlerts.push({ type: 'warning', msg: `Has agotado tus ${stat.unit} de ${stat.name}.` });
      else if (stat.restante <= (stat.total * 0.2)) newAlerts.push({ type: 'info', msg: `Pocos ${stat.unit} de ${stat.name} (${stat.restante.toFixed(2)} restantes).` });
    });
    return newAlerts;
  }, [stats]);

  const calendarDayMap = useMemo(() => {
    const map = {};
    entries.forEach(entry => {
      const categoryStyle = categories[entry.category];
      (entry.dateList || []).forEach(dateStr => {
        if (!map[dateStr] || map[dateStr].status === 'previsto') {
          map[dateStr] = { status: entry.status, category: entry.category, style: entry.status === 'pedido' ? categoryStyle?.styleSolid : categoryStyle?.styleLight };
        }
      });
    });
    return map;
  }, [entries, categories]);

  // --- INTERACCIÓN DE CALENDARIO ---
  const handleDateMouseDown = (e, dateStr) => {
    e.preventDefault();
    setSelectionStart(dateStr);
    setSelectionEnd(dateStr);
    setIsSelecting(true);
  };

  const handleDateMouseEnter = (dateStr) => {
    if (isSelecting) setSelectionEnd(dateStr);
  };

  const handleDateMouseUp = () => {
    if (isSelecting && selectionStart && selectionEnd) {
      // FUNCIONALIDAD 1: Si es un solo clic y el día ya está asignado, eliminarlo.
      if (selectionStart === selectionEnd && calendarDayMap[selectionStart]) {
        const dateStr = selectionStart;
        const updatedEntries = entries.map(ent => {
          if (ent.dateList && ent.dateList.includes(dateStr)) {
            const newDates = ent.dateList.filter(d => d !== dateStr);
            const catUnit = categories[ent.category]?.unit || 'días';
            const newAmount = catUnit === 'días' ? newDates.length : ent.amount;
            return { ...ent, dateList: newDates, amount: newAmount };
          }
          return ent;
        }).filter(ent => {
          const catUnit = categories[ent.category]?.unit || 'días';
          if (catUnit === 'días' && (!ent.dateList || ent.dateList.length === 0)) return false;
          return true;
        });
        
        setEntries(updatedEntries);
      } 
      // Si no es un día ya asignado, o es una selección arrastrando, abrir el formulario
      else {
        const start = new Date(selectionStart < selectionEnd ? selectionStart : selectionEnd);
        const end = new Date(selectionStart < selectionEnd ? selectionEnd : selectionStart);
        const selectedRange = [];
        let current = new Date(start);
        while (current <= end) {
          selectedRange.push(current.toISOString().split('T')[0]);
          current.setDate(current.getDate() + 1);
        }
        
        const defaultCat = Object.values(categories)[0];
        setFormData({ 
          id: '', 
          category: defaultCat?.id || 'VACACIONES', 
          status: 'pedido', 
          dates: '', 
          dateList: selectedRange, 
          amount: defaultCat?.unit === 'días' ? selectedRange.length.toString() : ''
        });
        setIsEditing(false);
        resetDateInputs();
        setIsFormModalOpen(true);
      }
    }
    setIsSelecting(false);
    setSelectionStart(null);
    setSelectionEnd(null);
  };

  // --- MANEJO DE FORMULARIO DE FECHAS EN MODAL ---
  const resetDateInputs = () => {
    setNewDateStart('');
    setNewDateEnd('');
    setDateInputMode('single');
  };

  const handleRemoveDateFromForm = (dateToRemove) => {
    const updatedList = formData.dateList.filter(d => d !== dateToRemove);
    setFormData(prev => ({
      ...prev,
      dateList: updatedList,
      amount: categories[prev.category]?.unit === 'días' ? updatedList.length.toString() : prev.amount
    }));
  };

  const handleAddDateToForm = () => {
    if (!newDateStart) return;
    let datesToAdd = [];

    if (dateInputMode === 'single') {
      datesToAdd.push(newDateStart);
    } else {
      if (!newDateEnd) return;
      let start = new Date(newDateStart);
      let end = new Date(newDateEnd);
      if (start > end) {
        const temp = start; start = end; end = temp;
      }
      let current = new Date(start);
      while (current <= end) {
        datesToAdd.push(current.toISOString().split('T')[0]);
        current.setDate(current.getDate() + 1);
      }
    }

    const currentSet = new Set(formData.dateList);
    datesToAdd.forEach(d => currentSet.add(d));
    const updatedList = Array.from(currentSet).sort();

    setFormData(prev => ({
      ...prev,
      dateList: updatedList,
      amount: categories[prev.category]?.unit === 'días' ? updatedList.length.toString() : prev.amount
    }));

    setNewDateStart('');
    setNewDateEnd('');
  };

  // --- MANEJO DE FORMULARIO PRINCIPAL ---
  const handleInputChange = (e) => {
    const { name, value } = e.target;
    setFormData(prev => {
      const updates = { [name]: value };
      if (name === 'category' && categories[value]?.unit === 'días' && prev.dateList.length > 0) {
        updates.amount = prev.dateList.length.toString();
      }
      return { ...prev, ...updates };
    });
  };

  const handleSubmit = (e) => {
    e.preventDefault();
    const amountNum = parseFloat(formData.amount);
    if (isNaN(amountNum) || amountNum <= 0) return;
    
    let description = formData.dates;
    if (!description && formData.dateList.length > 0) {
      // Intenta generar una descripción limpia agrupada si no hay una manual
      description = formData.dateList.map(d => d.split('-').reverse().join('/')).join(', ');
    }
    
    const payload = { ...formData, dates: description, amount: amountNum };

    // FUNCIONALIDAD 2: Limpiar días duplicados en otras entradas (Reajuste automático)
    const cleanedEntries = entries.map(ent => {
      if (isEditing && ent.id === formData.id) return ent; // Ignorar la entrada que se está editando
      
      if (ent.dateList && ent.dateList.length > 0) {
        // Filtrar cualquier fecha que ya esté presente en el nuevo formData.dateList
        const newDates = ent.dateList.filter(d => !formData.dateList.includes(d));
        
        // Si la lista de fechas cambió, actualizamos la entrada
        if (newDates.length !== ent.dateList.length) {
          const catUnit = categories[ent.category]?.unit || 'días';
          const newAmount = catUnit === 'días' ? newDates.length : ent.amount;
          return { ...ent, dateList: newDates, amount: newAmount };
        }
      }
      return ent;
    }).filter(ent => {
      const catUnit = categories[ent.category]?.unit || 'días';
      // Si era de días y se quedó con 0 días, la eliminamos para no dejar basura
      if (catUnit === 'días' && (!ent.dateList || ent.dateList.length === 0)) return false;
      return true;
    });

    // Guardar el listado procesado y sin duplicados
    if (isEditing) {
      setEntries(cleanedEntries.map(ent => ent.id === formData.id ? payload : ent));
    } else {
      setEntries([...cleanedEntries, { ...payload, id: Date.now().toString() }]);
    }
    
    closeModal();
  };

  const handleEdit = (entry) => {
    setFormData({ ...entry, amount: entry.amount.toString(), dateList: entry.dateList || [] });
    setIsEditing(true);
    setSelectedCategory(null);
    resetDateInputs();
    setIsFormModalOpen(true);
  };

  const handleDelete = (id) => setEntries(entries.filter(ent => ent.id !== id));

  const closeModal = () => {
    setIsFormModalOpen(false);
    setIsEditing(false);
    setFormData({ id: '', category: Object.values(categories)[0]?.id || 'VACACIONES', status: 'pedido', dates: '', dateList: [], amount: '' });
    resetDateInputs();
  };

  const openNewForm = () => {
    setIsEditing(false);
    setFormData({ id: '', category: Object.values(categories)[0]?.id || 'VACACIONES', status: 'pedido', dates: '', dateList: [], amount: '' });
    resetDateInputs();
    setIsFormModalOpen(true);
  };

  // --- CONFIGURACIÓN DE CATEGORÍAS ---
  const startEditCategory = (cat) => {
    setEditingCatId(cat.id);
    setCatEditForm({ name: cat.name, total: cat.total.toString(), unit: cat.unit, color: cat.color });
  };

  const saveCategory = (id) => {
    const totalVal = parseFloat(catEditForm.total);
    if (!catEditForm.name || isNaN(totalVal)) return;
    const colorScheme = COLOR_OPTIONS.find(c => c.bg === catEditForm.color) || COLOR_OPTIONS[0];

    setCategories(prev => ({
      ...prev,
      [id]: {
        ...prev[id],
        name: catEditForm.name,
        total: totalVal,
        unit: catEditForm.unit,
        color: colorScheme.bg,
        styleSolid: colorScheme.solid,
        styleLight: colorScheme.light
      }
    }));
    setEditingCatId(null);
  };

  const addNewCategory = () => {
    const id = `CAT_${Date.now()}`;
    const colorScheme = COLOR_OPTIONS[Math.floor(Math.random() * COLOR_OPTIONS.length)];
    const newCat = {
      id, name: 'Nueva Categoría', total: 0, unit: 'días',
      color: colorScheme.bg, styleSolid: colorScheme.solid, styleLight: colorScheme.light
    };
    setCategories(prev => ({ ...prev, [id]: newCat }));
    startEditCategory(newCat);
  };

  const deleteCategory = (id) => {
    if (Object.keys(categories).length <= 1) return;
    const { [id]: removed, ...rest } = categories;
    setCategories(rest);
    setEntries(entries.filter(e => e.category !== id));
  };
  
  // --- IMPORT / EXPORT ---
  const exportJSON = () => {
    const dataStr = JSON.stringify({ entries, categories }, null, 2);
    const blob = new Blob([dataStr], { type: "application/json" });
    const url = URL.createObjectURL(blob);
    const link = document.createElement('a');
    link.href = url;
    link.download = `vacaciones_backup_${new Date().toISOString().split('T')[0]}.json`;
    link.click();
    URL.revokeObjectURL(url);
  };

  const importJSON = (e) => {
    const file = e.target.files[0];
    if (!file) return;
    const reader = new FileReader();
    reader.onload = (event) => {
      try {
        const importedData = JSON.parse(event.target.result);
        if (importedData.entries) setEntries(importedData.entries.map(ent => ({ ...ent, dateList: ent.dateList || [] })));
        else if (Array.isArray(importedData)) setEntries(importedData.map(ent => ({ ...ent, dateList: ent.dateList || [] }))); 
        if (importedData.categories) setCategories(importedData.categories);
      } catch (error) { console.error("Error al importar", error); }
    };
    reader.readAsText(file);
    e.target.value = '';
  };

  const ProgressBar = ({ stat }) => {
    const percentPedido = Math.min((stat.pedido / stat.total) * 100, 100);
    const percentPrevisto = Math.min((stat.previsto / stat.total) * 100, 100);
    const isOver = stat.restante < 0;
    return (
      <div className="w-full mt-2">
        <div className="flex justify-between text-xs text-slate-500 mb-1">
          <span>0 {stat.unit}</span>
          <span>{stat.total} {stat.unit}</span>
        </div>
        <div className="h-3 w-full bg-slate-200 rounded-full overflow-hidden flex relative">
          <div style={{ width: `${percentPedido}%` }} className={`${stat.color} transition-all duration-500`}></div>
          <div style={{ width: `${percentPrevisto}%` }} className={`bg-slate-300 transition-all duration-500 opacity-60`}></div>
          {isOver && <div className="absolute top-0 right-0 bottom-0 left-0 bg-red-500 opacity-50 flex items-center justify-center text-[10px] text-white font-bold">¡Excedido!</div>}
        </div>
      </div>
    );
  };

  const renderMonthCalendar = (year, monthIndex) => {
    const daysInMonth = new Date(year, monthIndex + 1, 0).getDate();
    const firstDay = new Date(year, monthIndex, 1).getDay();
    const startOffset = firstDay === 0 ? 6 : firstDay - 1;
    const grid = [];
    for (let i = 0; i < startOffset; i++) grid.push(null);
    for (let i = 1; i <= daysInMonth; i++) grid.push(i);
    return (
      <div key={monthIndex} className="bg-white rounded-xl border border-slate-100 p-4 shadow-sm select-none">
        <h3 className="font-bold text-slate-700 text-center mb-3 uppercase tracking-wider text-sm">{MONTHS[monthIndex]}</h3>
        <div className="grid grid-cols-7 gap-1 text-center mb-1">
          {DAYS_OF_WEEK.map(d => <div key={d} className="text-[10px] font-bold text-slate-400">{d}</div>)}
        </div>
        <div className="grid grid-cols-7 gap-1 text-center">
          {grid.map((day, idx) => {
            if (!day) return <div key={`empty-${idx}`} className="h-8"></div>;
            const dateStr = `${year}-${String(monthIndex + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
            const dayData = calendarDayMap[dateStr];
            
            const isSelectingDay = selectionStart && selectionEnd && 
              dateStr >= (selectionStart < selectionEnd ? selectionStart : selectionEnd) && 
              dateStr <= (selectionStart < selectionEnd ? selectionEnd : selectionStart);
            
            let baseClasses = "h-8 flex items-center justify-center text-sm rounded-md transition-all cursor-pointer ";
            
            if (isSelectingDay) {
              baseClasses += "bg-blue-100 ring-2 ring-blue-400 scale-105 z-10 font-bold text-blue-800 shadow-sm ";
            } else if (dayData) {
              baseClasses += dayData.style;
            } else {
              baseClasses += "text-slate-600 hover:bg-slate-100";
            }
            
            return (
              <div 
                key={idx} 
                className={baseClasses} 
                title={dayData ? `${categories[dayData.category]?.name || dayData.category} (${dayData.status}) - Clic para eliminar` : 'Clic y arrastra para seleccionar'}
                onMouseDown={(e) => handleDateMouseDown(e, dateStr)}
                onMouseEnter={() => handleDateMouseEnter(dateStr)}
              >
                {day}
              </div>
            );
          })}
        </div>
      </div>
    );
  };

  const CategoryDetailOverlay = () => {
    if (!selectedCategory) return null;
    const catData = stats[selectedCategory];
    const confirmedItems = catData.items.filter(i => i.status === 'pedido').sort((a,b) => new Date(a.dateList[0]) - new Date(b.dateList[0]));
    const plannedItems = catData.items.filter(i => i.status === 'previsto').sort((a,b) => new Date(a.dateList[0]) - new Date(b.dateList[0]));

    return (
      <div className="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-50 flex justify-end animate-in fade-in duration-200" onClick={() => setSelectedCategory(null)}>
        <div className="w-full max-w-md bg-white h-full shadow-2xl flex flex-col animate-in slide-in-from-right duration-300" onClick={e => e.stopPropagation()}>
          <div className="p-6 border-b border-slate-100 flex items-center justify-between">
            <div className="flex items-center gap-3">
              <div className={`w-4 h-4 rounded-full ${catData.color}`}></div>
              <h2 className="text-xl font-bold text-slate-800">{catData.name}</h2>
            </div>
            <button onClick={() => setSelectedCategory(null)} className="p-2 hover:bg-slate-100 rounded-full text-slate-400 transition-colors"><X size={24}/></button>
          </div>
          
          <div className="flex-1 overflow-y-auto p-6 space-y-8">
            <section>
              <div className="flex items-center gap-2 mb-4 text-blue-600">
                <CheckCircle size={18} />
                <h3 className="font-bold uppercase text-xs tracking-wider">Confirmados ({catData.pedido} {catData.unit})</h3>
              </div>
              <div className="space-y-3">
                {confirmedItems.length === 0 ? (
                  <p className="text-sm text-slate-400 italic">No hay días confirmados.</p>
                ) : confirmedItems.map(item => (
                  <div key={item.id} className="p-3 bg-blue-50/50 border border-blue-100 rounded-xl relative group">
                    <p className="text-sm font-semibold text-slate-800">{item.dates || 'Sin descripción'}</p>
                    <p className="text-xs text-slate-500 mt-1">{item.amount} {catData.unit}</p>
                    <div className="absolute top-3 right-3 opacity-0 group-hover:opacity-100 transition-opacity">
                      <button onClick={() => handleEdit(item)} className="p-1 text-slate-400 hover:text-blue-600"><Edit2 size={14}/></button>
                    </div>
                  </div>
                ))}
              </div>
            </section>

            <section>
              <div className="flex items-center gap-2 mb-4 text-slate-400">
                <Calendar size={18} />
                <h3 className="font-bold uppercase text-xs tracking-wider">Previstos ({catData.previsto} {catData.unit})</h3>
              </div>
              <div className="space-y-3">
                {plannedItems.length === 0 ? (
                  <p className="text-sm text-slate-400 italic">No hay días previstos.</p>
                ) : plannedItems.map(item => (
                  <div key={item.id} className="p-3 bg-slate-50 border border-slate-200 rounded-xl relative group">
                    <p className="text-sm font-semibold text-slate-700">{item.dates || 'Sin descripción'}</p>
                    <p className="text-xs text-slate-500 mt-1">{item.amount} {catData.unit}</p>
                    <div className="absolute top-3 right-3 opacity-0 group-hover:opacity-100 transition-opacity">
                      <button onClick={() => handleEdit(item)} className="p-1 text-slate-400 hover:text-blue-600"><Edit2 size={14}/></button>
                    </div>
                  </div>
                ))}
              </div>
            </section>
          </div>

          <div className="p-6 bg-slate-50 border-t border-slate-100">
            <div className="flex justify-between items-center text-sm">
              <span className="text-slate-500">Restante:</span>
              <span className={`font-bold text-lg ${catData.restante < 0 ? 'text-red-600' : 'text-slate-800'}`}>
                {catData.restante} {catData.unit}
              </span>
            </div>
          </div>
        </div>
      </div>
    );
  };

  if (!isLoaded) return <div className="p-8 text-center text-slate-500">Cargando...</div>;

  return (
    <div className="min-h-screen bg-slate-50 text-slate-800 font-sans p-4 md:p-8" onMouseUp={handleDateMouseUp} onMouseLeave={handleDateMouseUp}>
      <CategoryDetailOverlay />

      {/* MODAL DE FORMULARIO DE VACACIONES */}
      {isFormModalOpen && (
        <div className="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-[60] flex items-center justify-center p-4 animate-in fade-in duration-200" onClick={closeModal}>
          <div className="bg-white w-full max-w-lg rounded-2xl shadow-2xl overflow-hidden animate-in zoom-in-95 duration-200 flex flex-col max-h-[90vh]" onClick={e => e.stopPropagation()}>
            <div className="p-5 border-b border-slate-100 flex items-center justify-between bg-slate-50 flex-shrink-0">
              <div className="flex items-center gap-2">
                {isEditing ? <Edit2 className="text-blue-500" size={20} /> : <Plus className="text-blue-500" size={20} />}
                <h2 className="text-lg font-bold text-slate-800">{isEditing ? 'Editar Registro' : 'Añadir Días'}</h2>
              </div>
              <button onClick={closeModal} className="p-2 hover:bg-slate-200 rounded-full text-slate-400"><X size={20}/></button>
            </div>
            
            <form onSubmit={handleSubmit} className="p-6 space-y-5 overflow-y-auto">
              <div className="space-y-1.5">
                <label className="block text-sm font-medium text-slate-700">Categoría</label>
                <select name="category" value={formData.category} onChange={handleInputChange} className="w-full rounded-lg border-slate-200 bg-slate-50 border p-2.5 text-sm focus:ring-2 focus:ring-blue-500 outline-none transition-all">
                  {Object.values(categories).map(cat => (<option key={cat.id} value={cat.id}>{cat.name}</option>))}
                </select>
              </div>

              {/* GESTIÓN AVANZADA DE FECHAS EN EL MODAL */}
              <div className="space-y-1.5">
                <label className="block text-sm font-medium text-slate-700">Fechas Seleccionadas</label>
                
                {/* Lista de fechas con opción de eliminar */}
                <div className="flex flex-wrap gap-1.5 p-3 bg-slate-50 border border-slate-200 rounded-lg max-h-32 overflow-y-auto">
                  {formData.dateList.length === 0 && <span className="text-xs text-slate-400 italic">Ninguna fecha seleccionada</span>}
                  {formData.dateList.map((dateStr, i) => (
                    <span key={i} className="inline-flex items-center gap-1.5 px-2 py-1 bg-white border border-slate-200 text-slate-700 text-xs rounded-md shadow-sm font-medium">
                      {dateStr.split('-').reverse().join('/')}
                      <button type="button" onClick={() => handleRemoveDateFromForm(dateStr)} className="text-slate-400 hover:text-red-500 transition-colors">
                        <X size={12}/>
                      </button>
                    </span>
                  ))}
                </div>

                {/* Panel para añadir nuevas fechas (sueltas o rango) */}
                <div className="mt-2 bg-slate-100 p-3 rounded-lg border border-slate-200">
                  <div className="flex items-center justify-between text-xs text-slate-500 mb-2">
                    <span className="font-semibold uppercase tracking-wider">Añadir más días</span>
                    <div className="flex gap-3">
                      <label className="flex items-center gap-1 cursor-pointer">
                        <input type="radio" checked={dateInputMode==='single'} onChange={()=>setDateInputMode('single')} className="text-blue-500 focus:ring-blue-500 h-3 w-3" /> 
                        Día suelto
                      </label>
                      <label className="flex items-center gap-1 cursor-pointer">
                        <input type="radio" checked={dateInputMode==='range'} onChange={()=>setDateInputMode('range')} className="text-blue-500 focus:ring-blue-500 h-3 w-3" /> 
                        Rango
                      </label>
                    </div>
                  </div>
                  <div className="flex gap-2">
                    <input type="date" value={newDateStart} onChange={e => setNewDateStart(e.target.value)} className="flex-1 rounded-md border-slate-200 bg-white border p-2 text-sm outline-none focus:ring-2 focus:ring-blue-500" />
                    {dateInputMode === 'range' && (
                      <>
                        <span className="text-slate-400 self-center">-</span>
                        <input type="date" value={newDateEnd} onChange={e => setNewDateEnd(e.target.value)} min={newDateStart} className="flex-1 rounded-md border-slate-200 bg-white border p-2 text-sm outline-none focus:ring-2 focus:ring-blue-500" />
                      </>
                    )}
                    <button type="button" onClick={handleAddDateToForm} className="px-3 py-2 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-md transition-colors shadow-sm flex items-center gap-1">
                      <Plus size={16}/>
                    </button>
                  </div>
                </div>
              </div>

              <div className="space-y-1.5">
                <label className="block text-sm font-medium text-slate-700">Descripción (Opcional)</label>
                <input type="text" name="dates" value={formData.dates} onChange={handleInputChange} placeholder="Ej: Viaje a Roma, Asuntos propios..." className="w-full rounded-lg border-slate-200 bg-slate-50 border p-2.5 text-sm focus:ring-2 focus:ring-blue-500 outline-none transition-all" />
              </div>

              <div className="space-y-1.5">
                <label className="block text-sm font-medium text-slate-700 flex justify-between">
                  <span>Cantidad ({categories[formData.category]?.unit || 'días'})</span>
                  {categories[formData.category]?.unit === 'días' && <span className="text-xs text-blue-500 font-normal">Autocalculado</span>}
                </label>
                <input type="number" name="amount" value={formData.amount} onChange={handleInputChange} placeholder="Ej: 1" step="0.01" min="0" className="w-full rounded-lg border-slate-200 bg-slate-50 border p-2.5 text-sm focus:ring-2 focus:ring-blue-500 outline-none transition-all" required />
              </div>

              <div className="space-y-2 pt-2">
                <label className="block text-sm font-medium text-slate-700">Estado</label>
                <div className="grid grid-cols-2 gap-3">
                  <label className={`flex items-center justify-center gap-2 p-3 rounded-lg border cursor-pointer transition-all ${formData.status === 'pedido' ? 'bg-blue-50 border-blue-500 text-blue-700 font-semibold shadow-sm' : 'bg-white border-slate-200 text-slate-500 hover:bg-slate-50'}`}>
                    <input type="radio" name="status" value="pedido" checked={formData.status === 'pedido'} onChange={handleInputChange} className="hidden" />
                    <CheckCircle size={16} /> <span className="text-xs uppercase tracking-tight">Confirmado</span>
                  </label>
                  <label className={`flex items-center justify-center gap-2 p-3 rounded-lg border cursor-pointer transition-all ${formData.status === 'previsto' ? 'bg-slate-100 border-slate-400 text-slate-700 font-semibold shadow-sm' : 'bg-white border-slate-200 text-slate-500 hover:bg-slate-50'}`}>
                    <input type="radio" name="status" value="previsto" checked={formData.status === 'previsto'} onChange={handleInputChange} className="hidden" />
                    <Calendar size={16} /> <span className="text-xs uppercase tracking-tight">Previsto</span>
                  </label>
                </div>
              </div>

              <div className="pt-4 flex gap-3">
                <button type="button" onClick={closeModal} className="flex-1 px-4 py-2.5 bg-slate-100 hover:bg-slate-200 text-slate-700 text-sm font-semibold rounded-lg transition-colors">Cancelar</button>
                <button type="submit" className="flex-1 px-4 py-2.5 bg-slate-800 hover:bg-slate-900 text-white text-sm font-semibold rounded-lg transition-colors flex justify-center items-center gap-2 shadow-sm">
                  <Save size={18} /> {isEditing ? 'Actualizar' : 'Guardar'}
                </button>
              </div>
            </form>
          </div>
        </div>
      )}
      
      <div className="max-w-7xl mx-auto space-y-6">
        <header className="flex flex-col md:flex-row justify-between items-center bg-white p-6 rounded-2xl shadow-sm border border-slate-100 gap-4">
          <div className="flex items-center gap-3">
            <div className="p-3 bg-blue-100 text-blue-600 rounded-xl"><Briefcase size={28} /></div>
            <div>
              <h1 className="text-2xl font-bold text-slate-800">Mis Vacaciones</h1>
              <p className="text-sm text-slate-500">Saldo basado en días confirmados</p>
            </div>
          </div>
          <div className="flex gap-2">
            <input type="file" accept=".json" ref={fileInputRef} onChange={importJSON} className="hidden" />
            <button onClick={() => fileInputRef.current.click()} className="flex items-center gap-2 px-4 py-2 text-sm font-medium text-slate-600 bg-slate-100 rounded-lg hover:bg-slate-200 transition-colors hidden sm:flex"><Upload size={16} /> Importar</button>
            <button onClick={exportJSON} className="flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-slate-800 rounded-lg hover:bg-slate-700 transition-colors hidden sm:flex"><Download size={16} /> Exportar</button>
            <button onClick={openNewForm} className="flex items-center gap-2 px-4 py-2 text-sm font-medium text-white bg-blue-600 rounded-lg hover:bg-blue-700 transition-colors shadow-sm"><Plus size={16} /> Añadir</button>
          </div>
        </header>

        {alerts.length > 0 && (
          <div className="space-y-2">
            {alerts.map((alert, idx) => (
              <div key={idx} className={`p-4 rounded-xl flex items-start gap-3 border ${alert.type === 'danger' ? 'bg-red-50 text-red-800 border-red-200' : alert.type === 'warning' ? 'bg-amber-50 text-amber-800 border-amber-200' : 'bg-blue-50 text-blue-800 border-blue-200'}`}>
                {alert.type === 'danger' ? <AlertTriangle size={20} className="mt-0.5 flex-shrink-0" /> : <Info size={20} className="mt-0.5 flex-shrink-0" />}
                <span className="font-medium text-sm">{alert.msg}</span>
              </div>
            ))}
          </div>
        )}

        <div className="space-y-6">
          <div className="flex flex-col sm:flex-row bg-white rounded-xl shadow-sm border border-slate-100 p-1.5 overflow-hidden">
            <button onClick={() => setActiveTab('dashboard')} className={`flex-1 flex items-center justify-center gap-2 py-2.5 px-4 text-sm font-semibold rounded-lg transition-colors ${activeTab === 'dashboard' ? 'bg-slate-800 text-white shadow' : 'text-slate-500 hover:text-slate-800 hover:bg-slate-100'}`}><LayoutDashboard size={18} /> Resumen</button>
            <button onClick={() => setActiveTab('calendar')} className={`flex-1 flex items-center justify-center gap-2 py-2.5 px-4 text-sm font-semibold rounded-lg transition-colors ${activeTab === 'calendar' ? 'bg-slate-800 text-white shadow' : 'text-slate-500 hover:text-slate-800 hover:bg-slate-100'}`}><CalendarDays size={18} /> Calendario</button>
            <button onClick={() => setActiveTab('settings')} className={`flex-1 flex items-center justify-center gap-2 py-2.5 px-4 text-sm font-semibold rounded-lg transition-colors ${activeTab === 'settings' ? 'bg-slate-800 text-white shadow' : 'text-slate-500 hover:text-slate-800 hover:bg-slate-100'}`}><Settings size={18} /> Configuración</button>
          </div>

          {activeTab === 'dashboard' && (
            <div className="space-y-6 animate-in fade-in zoom-in-95 duration-200">
              <div className="grid grid-cols-2 md:grid-cols-4 gap-4">
                <div className="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 flex flex-col items-center justify-center text-center">
                  <span className="text-xs text-slate-500 font-medium mb-1 uppercase tracking-wider">Total Días</span>
                  <span className="text-3xl font-bold text-slate-800">{globalStats.total}</span>
                </div>
                <div className="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 flex flex-col items-center justify-center text-center">
                  <span className="text-xs text-blue-500 font-medium mb-1 uppercase tracking-wider">Confirmados</span>
                  <span className="text-3xl font-bold text-blue-600">{globalStats.pedido}</span>
                </div>
                <div className="bg-white p-5 rounded-2xl shadow-sm border border-slate-100 flex flex-col items-center justify-center text-center">
                  <span className="text-xs text-slate-400 font-medium mb-1 uppercase tracking-wider">Previstos</span>
                  <span className="text-3xl font-bold text-slate-400">{globalStats.previsto}</span>
                </div>
                <div className="bg-slate-800 p-5 rounded-2xl shadow-sm flex flex-col items-center justify-center text-center">
                  <span className="text-xs text-slate-300 font-medium mb-1 uppercase tracking-wider">Restantes</span>
                  <span className={`text-3xl font-bold ${globalStats.restante < 0 ? 'text-red-400' : 'text-white'}`}>{globalStats.restante}</span>
                </div>
              </div>

              <div className="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
                <div className="p-5 border-b border-slate-100 flex items-center justify-between">
                  <div className="flex items-center gap-2"><PieChart className="text-slate-400" size={20} /><h2 className="text-lg font-bold text-slate-800">Desglose por Categoría</h2></div>
                  <span className="text-[10px] uppercase font-bold text-slate-400 bg-slate-50 px-2 py-1 rounded-md">Haz clic para ver detalles</span>
                </div>
                <div className="p-5 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                  {Object.values(stats).map(stat => (
                    <div key={stat.id} onClick={() => setSelectedCategory(stat.id)} className="relative bg-slate-50 p-4 rounded-xl border border-slate-100 cursor-pointer hover:border-blue-300 hover:shadow-md transition-all group">
                      <div className="flex justify-between items-end mb-2">
                        <div>
                          <h3 className="font-semibold text-slate-800 flex items-center gap-2"><span className={`w-3 h-3 rounded-full ${stat.color}`}></span>{stat.name}</h3>
                          <p className="text-xs text-slate-500 mt-1"><span className="text-blue-600 font-medium group-hover:underline">{stat.pedido} confirmados</span> | {stat.previsto} previstos</p>
                        </div>
                        <div className="text-right">
                          <span className={`text-xl font-bold ${stat.restante < 0 ? 'text-red-500' : 'text-slate-700'}`}>{stat.restante % 1 === 0 ? stat.restante : stat.restante.toFixed(2)}</span>
                          <span className="text-xs text-slate-500 ml-1">{stat.unit}</span>
                        </div>
                      </div>
                      <ProgressBar stat={stat} />
                      <div className="absolute top-2 right-2 opacity-0 group-hover:opacity-100 text-blue-500 transition-opacity"><ArrowRight size={14}/></div>
                    </div>
                  ))}
                </div>
              </div>

              <div className="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
                <div className="p-5 border-b border-slate-100 flex items-center gap-2"><CalendarDays className="text-slate-400" size={20} /><h2 className="text-lg font-bold text-slate-800">Historial de Registros</h2></div>
                <div className="overflow-x-auto">
                  <table className="w-full text-sm text-left text-slate-600">
                    <thead className="text-xs text-slate-500 uppercase bg-slate-50">
                      <tr>
                        <th className="px-6 py-4 font-medium">Descripción</th>
                        <th className="px-6 py-4 font-medium">Categoría</th>
                        <th className="px-6 py-4 font-medium">Estado</th>
                        <th className="px-6 py-4 font-medium">Cantidad</th>
                        <th className="px-6 py-4 text-right font-medium">Acciones</th>
                      </tr>
                    </thead>
                    <tbody className="divide-y divide-slate-100">
                      {sortedEntries.length === 0 ? (
                        <tr><td colSpan="5" className="px-6 py-8 text-center text-slate-400">No hay registros aún.</td></tr>
                      ) : sortedEntries.map(entry => (
                        <tr key={entry.id} className="hover:bg-slate-50/50 transition-colors">
                          <td className="px-6 py-4 font-medium text-slate-800">
                            {entry.dates || 'Sin descripción'}
                            {entry.dateList && entry.dateList.length > 0 && <div className="text-[10px] text-slate-400 mt-0.5 font-normal">{entry.dateList.length} día(s) seleccionado(s)</div>}
                          </td>
                          <td className="px-6 py-4"><span className="inline-flex items-center gap-1.5 py-1 px-2.5 rounded-md text-xs font-medium bg-slate-100 text-slate-700"><span className={`w-1.5 h-1.5 rounded-full ${categories[entry.category]?.color?.split(' ')[0] || 'bg-slate-500'}`}></span>{categories[entry.category]?.name || entry.category}</span></td>
                          <td className="px-6 py-4">{entry.status === 'pedido' ? <span className="inline-flex items-center gap-1 py-1 px-2.5 rounded-md text-xs font-medium bg-blue-50 text-blue-700 border border-blue-100"><CheckCircle size={12} /> Confirmado</span> : <span className="inline-flex items-center gap-1 py-1 px-2.5 rounded-md text-xs font-medium bg-slate-100 text-slate-500 border border-slate-200"><Calendar size={12} /> Previsto</span>}</td>
                          <td className="px-6 py-4 font-medium text-slate-700">{entry.amount} <span className="text-slate-400 text-xs font-normal">{categories[entry.category]?.unit || 'días'}</span></td>
                          <td className="px-6 py-4 text-right">
                            <button onClick={() => handleEdit(entry)} className="p-1.5 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-lg transition-colors mr-1"><Edit2 size={16} /></button>
                            <button onClick={() => handleDelete(entry.id)} className="p-1.5 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-colors"><Trash2 size={16} /></button>
                          </td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          )}

          {activeTab === 'calendar' && (
            <div className="space-y-6 animate-in fade-in zoom-in-95 duration-200">
              <div className="bg-white rounded-2xl shadow-sm border border-slate-100 p-6">
                <div className="flex flex-col xl:flex-row justify-between items-start xl:items-center mb-6 gap-4">
                  <div className="flex items-center gap-4">
                    <h2 className="text-xl font-bold text-slate-800 flex items-center gap-2"><CalendarDays className="text-blue-500" /> Calendario</h2>
                    <div className="flex items-center bg-slate-100 rounded-lg p-1 border border-slate-200">
                      <button onClick={() => setCurrentYear(y => y - 1)} className="p-1 hover:bg-white text-slate-600 rounded-md transition-colors"><ChevronLeft size={18} /></button>
                      <span className="px-3 font-bold text-slate-700 w-16 text-center">{currentYear}</span>
                      <button onClick={() => setCurrentYear(y => y + 1)} className="p-1 hover:bg-white text-slate-600 rounded-md transition-colors"><ChevronRight size={18} /></button>
                    </div>
                    {/* Indicador visual de cómo seleccionar */}
                    <span className="hidden md:inline-flex items-center gap-1.5 px-3 py-1.5 bg-blue-50 text-blue-700 text-xs font-medium rounded-lg">
                      <Info size={14} /> Haz clic y arrastra para añadir días • Clic para eliminar asignados
                    </span>
                  </div>
                  <div className="flex flex-col gap-2 text-[11px] font-medium uppercase tracking-tight text-slate-600 bg-slate-50 p-3 rounded-xl border border-slate-100">
                    <div className="flex flex-wrap gap-x-4 gap-y-2">
                      {Object.values(categories).map(cat => <div key={cat.id} className="flex items-center gap-1.5"><div className={`w-3 h-3 ${cat.color} rounded-sm shadow-sm`}></div> {cat.name}</div>)}
                    </div>
                    <div className="flex flex-wrap gap-x-4 gap-y-2 text-[10px] text-slate-500 pt-2 border-t border-slate-200">
                      <div className="flex items-center gap-1.5"><div className="w-3 h-3 bg-slate-400 rounded-sm"></div> Confirmado (Sólido)</div>
                      <div className="flex items-center gap-1.5"><div className="w-3 h-3 bg-slate-100 border border-slate-400 rounded-sm"></div> Previsto (Contorno)</div>
                    </div>
                  </div>
                </div>
                {/* Calendario 100% de ancho */}
                <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
                  {MONTHS.map((_, index) => renderMonthCalendar(currentYear, index))}
                </div>
              </div>
            </div>
          )}

          {activeTab === 'settings' && (
            <div className="space-y-6 animate-in fade-in duration-300">
              <div className="bg-white rounded-2xl shadow-sm border border-slate-100 overflow-hidden">
                <div className="p-6 border-b border-slate-100 flex justify-between items-center bg-slate-50">
                  <div>
                    <h2 className="text-xl font-bold text-slate-800">Configuración de Categorías</h2>
                    <p className="text-sm text-slate-500 mt-1">Define tus tipos de ausencia y sus límites anuales.</p>
                  </div>
                  <button onClick={addNewCategory} className="px-4 py-2 bg-slate-800 hover:bg-slate-700 text-white text-sm font-bold rounded-lg flex items-center gap-2 transition-all">
                    <Plus size={18} /> Nueva Categoría
                  </button>
                </div>
                <div className="p-6">
                  <div className="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-6">
                    {Object.values(categories).map(cat => (
                      <div key={cat.id} className={`p-5 rounded-2xl border-2 transition-all ${editingCatId === cat.id ? 'border-blue-500 bg-blue-50/30' : 'border-slate-100 bg-white hover:border-slate-200'}`}>
                        {editingCatId === cat.id ? (
                          <div className="space-y-4">
                            <div className="flex gap-3">
                              <div className="flex-1">
                                <label className="text-[10px] font-bold text-slate-400 uppercase">Nombre</label>
                                <input type="text" value={catEditForm.name} onChange={e => setCatEditForm({...catEditForm, name: e.target.value})} className="w-full p-2 text-sm font-bold border rounded-lg bg-white" />
                              </div>
                              <div className="w-24">
                                <label className="text-[10px] font-bold text-slate-400 uppercase">Total</label>
                                <input type="number" step="0.01" value={catEditForm.total} onChange={e => setCatEditForm({...catEditForm, total: e.target.value})} className="w-full p-2 text-sm font-bold border rounded-lg bg-white" />
                              </div>
                            </div>
                            <div className="flex gap-3">
                              <div className="flex-1">
                                <label className="text-[10px] font-bold text-slate-400 uppercase">Unidad</label>
                                <select value={catEditForm.unit} onChange={e => setCatEditForm({...catEditForm, unit: e.target.value})} className="w-full p-2 text-sm border rounded-lg bg-white">
                                  <option value="días">Días</option>
                                  <option value="horas">Horas</option>
                                </select>
                              </div>
                              <div className="flex-1">
                                <label className="text-[10px] font-bold text-slate-400 uppercase">Color</label>
                                <div className="flex flex-wrap gap-1 mt-1">
                                  {COLOR_OPTIONS.map(c => (
                                    <button key={c.bg} onClick={() => setCatEditForm({...catEditForm, color: c.bg})} className={`w-6 h-6 rounded-full border-2 ${c.bg} ${catEditForm.color === c.bg ? 'border-slate-800 scale-110 shadow' : 'border-transparent hover:scale-105'}`}></button>
                                  ))}
                                </div>
                              </div>
                            </div>
                            <div className="flex gap-2 pt-2">
                              <button onClick={() => saveCategory(cat.id)} className="flex-1 py-2 bg-blue-600 text-white rounded-lg text-xs font-bold hover:bg-blue-700 transition-colors flex items-center justify-center gap-1"><Save size={14}/> Guardar</button>
                              <button onClick={() => setEditingCatId(null)} className="flex-1 py-2 bg-slate-200 text-slate-600 rounded-lg text-xs font-bold hover:bg-slate-300 transition-colors">Cancelar</button>
                            </div>
                          </div>
                        ) : (
                          <div className="flex items-center justify-between">
                            <div className="flex items-center gap-4">
                              <div className={`w-12 h-12 rounded-2xl ${cat.color} flex items-center justify-center text-white shadow-sm`}>
                                <Palette size={20} />
                              </div>
                              <div>
                                <h3 className="font-bold text-slate-800">{cat.name}</h3>
                                <p className="text-xs text-slate-500 font-medium">{cat.total} {cat.unit} anuales</p>
                              </div>
                            </div>
                            <div className="flex gap-1">
                              <button onClick={() => startEditCategory(cat)} className="p-2 text-slate-400 hover:text-blue-600 hover:bg-blue-50 rounded-xl transition-all"><Edit2 size={18}/></button>
                              <button onClick={() => deleteCategory(cat.id)} className="p-2 text-slate-400 hover:text-red-600 hover:bg-red-50 rounded-xl transition-all"><Trash2 size={18}/></button>
                            </div>
                          </div>
                        )}
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          )}
        </div>
      </div>
    </div>
  );
}

import { createRoot } from 'react-dom/client';
const root = createRoot(document.getElementById('root'));
root.render(<App />);
requestAnimationFrame(() => {
  const splash = document.getElementById('splash');
  if (splash) { splash.classList.add('hidden'); setTimeout(() => splash.remove(), 400); }
});
  </script>
</body>
</html>
